{
  "model": {
    "type": "minecraft:condition",
    "property": "minecraft:fishing_rod/cast",
    "on_true": {
      "type": "minecraft:select",
      "property": "minecraft:display_context",
      "cases": [
        {
          "when": [
            "gui",
            "ground"
          ],
          "model": {
            "type": "minecraft:model",
            "model": "fishcasting:item/shepherds_casting_rod_cast"
          }
        }
      ],
      "fallback": {
        "type": "minecraft:model",
        "model": "fishcasting:item/shepherds_casting_rod"
      }
    },
    "on_false": {
      "type": "minecraft:select",
      "property": "minecraft:display_context",
      "cases": [
        {
          "when": [
            "gui",
            "ground"
          ],
          "model": {
            "type": "minecraft:model",
            "model": "fishcasting:item/shepherds_casting_rod"
          }
        },
        {
          "when": [
            "fixed",
            "head"
          ],
          "model": {
            "type": "minecraft:model",
            "model": "fishcasting:item/shepherds_casting_rod_cast"
          }
        }
      ],
      "fallback": {
        "type": "minecraft:model",
        "model": "fishcasting:item/shepherds_casting_rod"
      }
    }
  }
}